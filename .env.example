# Copy this to .env and fill in your Enphase developer-app credentials.
# Never commit the real .env (it's gitignored).

# From your app at https://developer-v4.enphase.com
ENPHASE_API_KEY=
ENPHASE_CLIENT_ID=
ENPHASE_CLIENT_SECRET=

# Optional. Set to your dashboard's public URL only if you registered a redirect
# URI in your Enphase app and want the one-click OAuth callback instead of the
# default paste-the-code flow. Leave blank otherwise.
# PUBLIC_BASE_URL=https://solar.example.com
# ENPHASE_REDIRECT_URI=https://solar.example.com/api/enphase/callback
